{"hierarchy":{"paths":[["doc:\/\/com.opticalaberration.hummingbird\/documentation\/index"]]},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/hummingbird\/onetimepasswords"]}],"identifier":{"url":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/OneTimePasswords","interfaceLanguage":"swift"},"metadata":{"images":[{"identifier":"logo.png","type":"icon"}],"roleHeading":"Article","title":"One Time Passwords","role":"article"},"sections":[],"abstract":[{"text":"A one time password (OTP) valid for only one login session.","type":"text"}],"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/TOTP","doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/HOTP","doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/OTPAuthenticationExample"],"title":"Related Documentation"},{"anchor":"Authentication","identifiers":["doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/AuthenticatorMiddlewareGuide","doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/Sessions"],"title":"Authentication","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"OTPs avoid a number of shortcomings that are associated with traditional (static) password-based authentication. OTP generation algorithms typically make use of pseudo-randomness or randomness, making prediction of successor OTPs by an attacker difficult, and also cryptographic hash functions, which can be used to derive a value but are hard to reverse and therefore difficult for an attacker to obtain the data that was used for the hash. This is necessary because otherwise it would be easy to predict future OTPs by observing previous ones.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"HummingbirdAuth provides support for both time based (","type":"text"},{"identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/TOTP","isActive":true,"type":"reference"},{"text":") and counter based (","type":"text"},{"identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/HOTP","isActive":true,"type":"reference"},{"text":") one time passwords.","type":"text"}]},{"type":"heading","text":"Getting started","level":2,"anchor":"Getting-started"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Support for one time passwords is part of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP"},{"type":"text","text":" library in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/hummingbird-project\/hummingbird-auth"},{"type":"text","text":" package. If you don’t already have the "},{"type":"codeVoice","code":"hummingbird-auth"},{"type":"text","text":" library as a dependency in your project you use the following command line to add it."}]},{"type":"codeListing","code":["swift package add-dependency https:\/\/github.com\/hummingbird-project\/hummingbird-auth.git --from \"2.1.0\""],"syntax":null},{"inlineContent":[{"type":"text","text":"And then add the target dependency to your application using the following, replacing the "},{"type":"codeVoice","code":"<MyApp>"},{"type":"text","text":" text with the name of your application target."}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["swift package add-target-dependency HummingbirdOTP <MyApp> --package hummingbird-auth"]},{"level":2,"type":"heading","text":"Usage","anchor":"Usage"},{"inlineContent":[{"text":"To setup one time password authentication you need a shared secret for each user. Store the shared secret with your user in a database. You can generate an authentication URL to supply to the user which includes a base32 encoded version of the shared secret.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import HummingbirdOTP","","\/\/ create shared secret","let sharedSecret = \"random string\"","\/\/ store shared secret in database alongside user","storeSecretWithUser(secret: sharedSecret)","\/\/ create TOTP and generate authenticaion URL","let totp = TOTP(secret: sharedSecret)","let authenticationURL = totp.createAuthenticatorURL(label: \"MyURL\")"]},{"inlineContent":[{"text":"Generally this is provided to the user via a QR Code. Most phones will automatically open up an Authenticator app to store the URL when they scan the QR Code.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Authenticating","anchor":"Authenticating"},{"inlineContent":[{"type":"text","text":"Compute the time based one time password as follows"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let password = TOTP(secret: sharedSecret).compute()"]},{"inlineContent":[{"type":"text","text":"Compare it with the password provided by the user to verify the user credentials."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://com.opticalaberration.hummingbird/documentation/HummingbirdOTP":{"images":[{"identifier":"logo.png","type":"icon"}],"abstract":[{"text":"One time passwords","type":"text"}],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP","url":"\/documentation\/hummingbirdotp","kind":"symbol","title":"HummingbirdOTP","role":"collection"},"doc://com.opticalaberration.hummingbird/documentation/Hummingbird/Sessions":{"kind":"article","images":[{"type":"icon","identifier":"logo.png"}],"title":"Sessions","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/Sessions","type":"topic","abstract":[{"text":"Session based authentication","type":"text"}],"role":"article","url":"\/documentation\/hummingbird\/sessions"},"https://github.com/hummingbird-project/hummingbird-auth":{"url":"https:\/\/github.com\/hummingbird-project\/hummingbird-auth","titleInlineContent":[{"text":"hummingbird-auth","type":"text"}],"identifier":"https:\/\/github.com\/hummingbird-project\/hummingbird-auth","title":"hummingbird-auth","type":"link"},"doc://com.opticalaberration.hummingbird/documentation/Hummingbird/OTPAuthenticationExample":{"abstract":[{"type":"text","text":"Example demonstrating how to setup one time passwords, using sessions."}],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/OTPAuthenticationExample","url":"\/documentation\/hummingbird\/otpauthenticationexample","kind":"article","title":"OTP Authentication Example","role":"article"},"doc://com.opticalaberration.hummingbird/documentation/HummingbirdOTP/HOTP":{"kind":"symbol","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/HOTP","abstract":[{"text":"A counter based one time password (OTP)","type":"text"}],"title":"HOTP","type":"topic","role":"symbol","navigatorTitle":[{"text":"HOTP","kind":"identifier"}],"url":"\/documentation\/hummingbirdotp\/hotp","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HOTP","kind":"identifier"}]},"logo.png":{"type":"image","alt":null,"identifier":"logo.png","variants":[{"url":"\/images\/com.opticalaberration.hummingbird\/logo.png","traits":["1x","light"]}]},"doc://com.opticalaberration.hummingbird/documentation/Hummingbird/AuthenticatorMiddlewareGuide":{"images":[{"identifier":"logo.png","type":"icon"}],"abstract":[{"text":"Request authentication middleware","type":"text"}],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/Hummingbird\/AuthenticatorMiddlewareGuide","url":"\/documentation\/hummingbird\/authenticatormiddlewareguide","kind":"article","title":"Authenticator Middleware","role":"article"},"doc://com.opticalaberration.hummingbird/documentation/HummingbirdOTP/TOTP":{"kind":"symbol","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdOTP\/TOTP","title":"TOTP","type":"topic","abstract":[{"text":"A time based one time password (OTP)","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"TOTP","kind":"identifier"}],"url":"\/documentation\/hummingbirdotp\/totp","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TOTP","kind":"identifier"}]},"doc://com.opticalaberration.hummingbird/documentation/index":{"images":[{"identifier":"logo.png","type":"icon"}],"abstract":[{"type":"text","text":"Documentation for Hummingbird the lightweight, flexible, modern server framework."}],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/index","url":"\/documentation\/index","kind":"article","title":"Hummingbird Documentation","role":"collection"}}}