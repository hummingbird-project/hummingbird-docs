ocumentation\/Jobs","doc:\/\/com.opticalaberration.hummingbird\/documentation\/Mustache","doc:\/\/com.opticalaberration.hummingbird\/documentation\/PostgresMigrations","doc:\/\/com.opticalaberration.hummingbird\/documentation\/WSClient"],"generated":true}],"abstract":[{"text":"Adds support for upgrading HTTP connections to WebSocket.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/HummingbirdWebSocket"},"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[[]]},"variants":[{"paths":["\/documentation\/hummingbirdwebsocket"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"HummingbirdWebSocket","roleHeading":"Framework","symbolKind":"module","images":[{"identifier":"logo.png","type":"icon"}],"modules":[{"name":"HummingbirdWebSocket"}],"role":"collection","title":"HummingbirdWebSocket"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"WebSockets is a protocol providing simultaneous two-way communication channels over a single TCP connection. Unlike HTTP where client requests are paired with a server response, WebSockets allow for communication in both directions asynchronously, for a prolonged period of time."}]},{"type":"paragraph","inlineContent":[{"text":"It is designed to work over the HTTP ports 80 and 443 via an upgrade process where an initial HTTP request is sent before the connection is upgraded to a WebSocket connection.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"HummingbirdWebSocket allows you to implement an HTTP1 server with WebSocket upgrade. HummingbirdWebSocket passes all the tests in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/crossbario\/autobahn-testsuite"},{"type":"text","text":", supporting both compression and TLS."}]},{"type":"paragraph","inlineContent":[{"text":"To add ","type":"text"},{"code":"HummingbirdWebSocket","type":"codeVoice"},{"text":" to your project, run the following command in your Terminal:","type":"text"}]},{"type":"codeListing","syntax":"sh","code":["# From the root directory of your project","# Where Package.swift is located","","# Add the package to your dependencies","swift package add-dependency https:\/\/github.com\/hummingbird-project\/hummingbird-websocket.git --from 2.2.0","","# Add the target dependency to your target","swift package add-target-dependency HummingbirdWebSocket <MyApp> --package hummingbird-websocket"]},{"type":"paragraph","inlineContent":[{"text":"Make sure to replace ","type":"text"},{"type":"codeVoice","code":"<MyApp>"},{"text":" with the name of your App’s target.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To integrate ","type":"text"},{"code":"HummingbirdWebSocket","type":"codeVoice"},{"text":" into your project, you need to specify WebSocket support in your ","type":"text"},{"code":"Application","type":"codeVoice"},{"text":"’s configuration:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import Hummingbird","import HummingbirdWebSocket","","let app = Application(","    router: router,","    server: .http1WebSocketUpgrade { request, channel, logger in","        \/\/ upgrade if request URI is \"\/ws\"","        guard request.uri == \"\/ws\" else { return .dontUpgrade }","        \/\/ The upgrade response includes the headers to include in the response and ","        \/\/ the WebSocket handler","        return .upgrade([:]) { inbound, outbound, context in","            \/\/ Send \"Hello\" to the client","            try await outbound.write(.text(\"Hello\"))","            \/\/ Ending this function automatically closes the connection","        }","    }",")"]},{"type":"paragraph","inlineContent":[{"text":"Get started with the WebSockets here: ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.opticalaber