xt":" set","type":"text"},{"text":" ","type":"text"},{"text":"to whatever you like at any point to re-queue failed jobs. Moving processing or pending jobs","type":"text"},{"text":" ","type":"text"},{"text":"should only be done if you are certain there is nothing processing the job queue.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"pendingJobs: What to do with jobs tagged as pending"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"processingJobs: What to do with jobs tagged as processing"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"completedJobs: What to do with jobs tagged as completed"}]}]},{"content":[{"inlineContent":[{"text":"failedJobs: What to do with jobs tagged as failed","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"cancelledJobs: What to do with jobs tagged as cancelled","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"pausedJobs: What to do with jobs tagged as paused"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"logger: Optional logger to use when performing cleanup","type":"text"}],"type":"paragraph"}]}]},{"name":"Throws","type":"aside","content":[{"inlineContent":[{"type":"text","text":""}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/jobspostgres\/postgresjobqueue\/cleanup(pendingjobs:processingjobs:completedjobs:failedjobs:cancelledjobs:pausedjobs:logger:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.opticalaberration.hummingbird\/documentation\/JobsPostgres\/PostgresJobQueue\/cleanup(pendingJobs:processingJobs:completedJobs:failedJobs:cancelledJobs:pausedJobs:logger:)"},"sections":[],"metadata":{"extendedModule":"JobsPostgres","role":"symbol","modul