"todos-template-04.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open "},{"code":"Sources\/App\/App.swift","type":"codeVoice"}]}],"media":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This contains an "},{"type":"codeVoice","code":"App"},{"type":"text","text":" tagged with "},{"type":"codeVoice","code":"@main"},{"type":"text","text":". The "},{"type":"codeVoice","code":"main"},{"type":"text","text":" function in "},{"type":"codeVoice","code":"App"},{"type":"text","text":" sets up a "},{"type":"codeVoice","code":"ConfigReader"},{"type":"text","text":" to read configuration values from the command line arguments, environment variables, a "},{"type":"codeVoice","code":".env"},{"type":"text","text":" file and in-memory values in that order. Then it calls "},{"type":"codeVoice","code":"buildApplication(reader:)"},{"type":"text","text":" with the "},{"type":"codeVoice","code":"ConfigReader"},{"type":"text","text":" to create an "},{"type":"codeVoice","code":"Application"},{"type":"text","text":" and runs it using "},{"type":"codeVoice","code":"runService()"},{"type":"text","text":". You can find out more about the Configuration library "},{"type":"reference","identifier":"https:\/\/swiftpackageindex.com\/apple\/swift-configuration\/1.0.0\/documentation\/configuration","isActive":true},{"type":"text","text":"."}]}]},{"code":"todos-template-05.swift","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Open "},{"type":"codeVoice","code":"Sources\/App\/App+build.swift"},{"type":"text","text":" to find the `buildApplication(_:) function."}],"type":"paragraph"}],"media":null,"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Here we create a "},{"type":"codeVoice","code":"Logger"},{"type":"text","text":" with log level extracted from the configuration reader mentioned above. We then call a function "},{"type":"codeVoice","code":"buildRouter()"},{"type":"text","text":" and use the result of that to create our "},{"type":"codeVoice","code":"Application"},{"type":"text","text":". The application uses configuration values "},{"type":"codeVoice","code":"HTTP_HOST"},{"type":"text","text":" and "},{"type":"codeVoice","code":"HTTP_PORT"},{"type":"text","text":" to define its bind address."}],"type":"paragraph"}]},{"code":"todos-template-06.swift","runtimePreview":null,"content":[{"inlineContent":[{"text":"If we look further down the file we can find the ","type":"text"},{"code":"buildRouter()","type":"codeVoice"},{"text":" function.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","caption":[{"inlineContent":[{"type":"text","text":"Here we create the "},{"code":"Router","type":"codeVoice"},{"type":"text","text":". We add a logging middleware to it (this logs all requests to the router). The function uses a result builder to create a stack of middleware, but you can also use "},{"code":"Router.add(middleware:)","type":"codeVoice"},{"type":"text","text":" to add individual middleware. Finally we add a single endpoint GET "},{"code":"\/","type":"codeVoice"},{"type":"text","text":" which returns a String response: “Hello!”."}],"type":"paragraph"}]},{"code":"todos-template-07.sh","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"We can run this application and use curl to test it works.","type":"text"}]}],"media":null,"type":"step","caption":[]},{"code":"todos-template-08.sh","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we have a running server, lets add some functionality to it."}]}],"media":null,"type":"step","caption":[]}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Clone the Hummingbird template, configure a project and review the contents of the generated project."}],"type":"paragraph"}],"media":"hummingbird.png"}]}],"kind":"tasks"},{"title":"Add your application API","abstract":[{"type":"text","text":"Add some functionality to your application."}],"action":{"type":"reference","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-2-API","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true},"kind":"callToAction","featuredEyebrow":"Tutorial"}],"references":{"doc://com.opticalaberration.hummingbird/tutorials/Hummingbird/Todos-4-Postgres#Setup-your-Postgres-database":{"title":"Setup your Postgres database","role":"pseudoSymbol","kind":"section","url":"\/tutorials\/hummingbird\/todos-4-postgres#Setup-your-Postgres-database","abstract":[{"text":"Now we have a working API and a way to test it, lets look into storing our todos in a Postgres database with PostgresNIO.","type":"text"}],"type":"section","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-4-Postgres#Setup-your-Postgres-database"},"https://swiftpackageindex.com/apple/swift-configuration/1.0.0/documentation/configuration":{"titleInlineContent":[{"type":"text","text":"here"}],"type":"link","title":"here","identifier":"https:\/\/swiftpackageindex.com\/apple\/swift-configuration\/1.0.0\/documentation\/configuration","url":"https:\/\/swiftpackageindex.com\/apple\/swift-configuration\/1.0.0\/documentation\/configuration"},"doc://com.opticalaberration.hummingbird/tutorials/Hummingbird/Todos-4-Postgres":{"title":"Use PostgresNIO to store your Todos in a Postgres database","role":"project","kind":"project","url":"\/tutorials\/hummingbird\/todos-4-postgres","abstract":[{"type":"text","text":"Now we have a working API and a way to test it, lets look into storing our todos in a Postgres database with PostgresNIO."}],"estimatedTime":"15min","type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-4-Postgres"},"doc://com.opticalaberration.hummingbird/tutorials/Todos/Testing-your-application":{"title":"Testing your application","role":"article","kind":"article","url":"\/tutorials\/todos\/testing-your-application","abstract":[],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Todos\/Testing-your-application"},"doc://com.opticalaberration.hummingbird/tutorials/Hummingbird/Todos-2-API#Todo-Controller-and-Repository":{"abstract":[{"type":"text","text":"Add some functionality to your application."}],"identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-2-API#Todo-Controller-and-Repository","title":"Todo Controller and Repository","url":"\/tutorials\/hummingbird\/todos-2-api#Todo-Controller-and-Repository","type":"section","kind":"section","role":"pseudoSymbol"},"todos-template-05.swift":{"identifier":"todos-template-05.swift","fileName":"buildApplication() - Sources\/App\/App+build.swift","fileType":"swift","highlights":[],"syntax":"swift","type":"file","content":["\/\/\/  Build application","\/\/\/ - Parameter reader: configuration reader","func buildApplication(reader: ConfigReader) async throws -> some ApplicationProtocol {","    let logger = {","        var logger = Logger(label: \"Todos\")","        logger.logLevel = reader.string(forKey: \"log.level\", as: Logger.Level.self, default: .info)","        return logger","    }()","    let router = try buildRouter()","    let app = Application(","        router: router,","        configuration: ApplicationConfiguration(reader: reader.scoped(to: \"http\")),","        logger: logger","    )","    return app","}"]},"doc://com.opticalaberration.hummingbird/tutorials/Hummingbird/Todos-1-Template":{"abstract":[{"type":"text","text":"Create a simple web application using the Hummingbird template."}],"identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-1-Template","estimatedTime":"5min","title":"Create a Hummingbird application.","url":"\/tutorials\/hummingbird\/todos-1-template","type":"topic","kind":"project","role":"project"},"todos-template-06.swift":{"identifier":"todos-template-06.swift","fileName":"buildRouter() - Sources\/App\/App+build.swift","content":["\/\/\/ Build router","func buildRouter() -> Router<AppRequestContext> {","    let router = Router(context: AppRequestContext.self)","    \/\/ Add middleware","    router.addMiddleware {","        \/\/ logging middleware","        LogRequestsMiddleware(.info)","    }","    \/\/ Add default endpoint","    router.get(\"\/\") { _,_ in","        return \"Hello!\"","    }","    return router","}"],"type":"file","syntax":"swift","fileType":"swift","highlights":[]},"doc://com.opticalaberration.hummingbird/tutorials/Hummingbird/Todos-2-API":{"title":"Add your application API","role":"project","kind":"project","url":"\/tutorials\/hummingbird\/todos-2-api","abstract":[{"type":"text","text":"Add some functionality to your application."}],"estimatedTime":"15min","type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-2-API"},"doc://com.opticalaberration.hummingbird/tutorials/Todos":{"title":"Build a Todos application.","role":"overview","kind":"overview","url":"\/tutorials\/todos","abstract":[{"type":"text","text":"A tutorial showing you how to build a simple Todos application that allows you to store, access, edit and delete Todos in a database, using Hummingbird and PostgresNIO."}],"type":"topic","identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Todos"},"doc://com.opticalaberration.hummingbird/tutorials/Todos/API-Setup":{"abstract":[],"identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Todos\/API-Setup","title":"API Setup","url":"\/tutorials\/todos\/api-setup","type":"topic","kind":"article","role":"article"},"hummingbird.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/com.opticalaberration.hummingbird\/hummingbird.png"}],"alt":"Hummingbird logo","identifier":"hummingbird.png"},"doc://com.opticalaberration.hummingbird/tu