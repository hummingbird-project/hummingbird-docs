ype":"text","text":" sets up a "},{"code":"ConfigReader","type":"codeVoice"},{"type":"text","text":" to read configuration values from the command line arguments, environment variables, a "},{"code":".env","type":"codeVoice"},{"type":"text","text":" file and in-memory values in that order. Then it calls "},{"code":"buildApplication(reader:)","type":"codeVoice"},{"type":"text","text":" with the "},{"code":"ConfigReader","type":"codeVoice"},{"type":"text","text":" to create an "},{"code":"Application","type":"codeVoice"},{"type":"text","text":" and runs it using "},{"code":"runService()","type":"codeVoice"},{"type":"text","text":". You can find out more about the Configuration library "},{"isActive":true,"identifier":"https:\/\/swiftpackageindex.com\/apple\/swift-configuration\/1.0.0\/documentation\/configuration","type":"reference"},{"type":"text","text":"."}]}],"runtimePreview":null,"media":null,"code":"todos-template-04.swift","type":"step"},{"content":[{"inlineContent":[{"text":"Open ","type":"text"},{"code":"Sources\/App\/App+build.swift","type":"codeVoice"},{"text":" to find the `buildApplication(_:) function.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"text":"Here we create a ","type":"text"},{"code":"Logger","type":"codeVoice"},{"text":" with log level extracted from the configuration reader mentioned above. We then call a function ","type":"text"},{"code":"buildRouter()","type":"codeVoice"},{"text":" and use the result of that to create our ","type":"text"},{"code":"Application","type":"codeVoice"},{"text":". The application uses configuration values ","type":"text"},{"code":"HTTP_HOST","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"HTTP_PORT","type":"codeVoice"},{"text":" to define its bind address.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":null,"code":"todos-template-05.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If we look further down the file we can find the "},{"type":"codeVoice","code":"buildRouter()"},{"type":"text","text":" function."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"Here we create the ","type":"text"},{"type":"codeVoice","code":"Router"},{"text":". We add a logging middleware to it (this logs all requests to the router). The function uses a result builder to create a stack of middleware, but you can also use ","type":"text"},{"type":"codeVoice","code":"Router.add(middleware:)"},{"text":" to add individual middleware. Finally we add a single endpoint GET ","type":"text"},{"type":"codeVoice","code":"\/"},{"text":" which returns a String response: “Hello!”.","type":"text"}]}],"runtimePreview":null,"media":null,"code":"todos-template-06.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"text":"We can run this application and use curl to test it works.","type":"text"}]}],"caption":[],"runtimePreview":null,"media":null,"code":"todos-template-07.sh","type":"step"},{"content":[{"inlineContent":[{"text":"Now we have a running server, lets add some functionality to it.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":null,"code":"todos-template-08.sh","type":"step"}],"title":"Create your project","anchor":"Create-your-project","contentSection":[{"kind":"contentAndMedia","media":"hummingbird.png","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Clone the Hummingbird template, configure a project and review the contents of the generated project."}]}]}]}]},{"kind":"callToAction","abstract":[{"type":"text","text":"Add some functionality to your application."}],"title":"Add your application API","action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","isActive":true,"identifier":"doc:\/\/com.opticalaberration.hummingbird\/tutorials\/Hummingbird\/Todos-2-API","overridingTitle":"Get started"},"featuredEyebrow":"Tutorial"}],"schemaVersion":{"maj